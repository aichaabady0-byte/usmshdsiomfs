{
  "version": 2,
  "builds": [
    { "src": "api-*.js", "use": "@vercel/node" },
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "style.css", "use": "@vercel/static" },
    { "src": "script.js", "use": "@vercel/static" },
    { "src": "logo.png", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/members", "dest": "api-members.js" },
    { "src": "/api/auth", "dest": "api-auth.js" },
    { "src": "/api/videos", "dest": "api-videos.js" },
    { "src": "/logo.png", "dest": "/logo.png" },
    { "src": "/style.css", "dest": "/style.css" },
    { "src": "/script.js", "dest": "/script.js" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
